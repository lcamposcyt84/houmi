# Database
DATABASE_URL="mysql://root:@localhost:3306/houmi_dev"

# Admin credentials (solo para entorno de desarrollo, el sistema usará bcrypt en base de datos)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="your-secure-dev-password"

# JWT Secret (Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET="generate-a-strong-secret-key-in-production"

# Default exchange rate
DEFAULT_EXCHANGE_RATE="40.00"

# Mercantil Bank API (Production/Test)
MERCANTIL_MERCHANT_ID="your_merchant_id"
MERCANTIL_COMMERCE_CODE="your_commerce_code"
MERCANTIL_ENCRYPTION_KEY="your_encryption_key"
MERCANTIL_API_URL="your_api_url_here"

# Security Configurations
MERCANTIL_IP_WHITELIST_ENABLED="false"
MERCANTIL_ALLOWED_IPS=""
