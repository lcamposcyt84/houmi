# Prevenir listado de directorios
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Permitir que los headers de Autorización (Bearer Token) lleguen a PHP
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

    # Redirigir URL sin .php a archivos .php (ej. /api/health -> /api/health.php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>
